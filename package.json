{
  "name": "Daisy",
  "version": "1.5.1",
  "description": "Daisy：macOS AI 语音助手",
  "author": "Daisy",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && npm run copy-renderer && npm run build:settings",
    "build:watch": "tsc --watch",
    "build:settings": "vite build --config vite.settings.config.ts",
    "copy-renderer": "rm -rf dist/renderer && cp -R src/renderer dist/renderer",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "clean": "rm -rf dist releases",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "patch-package": "^8.0.1",
    "typescript": "^5.8.3",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@picovoice/porcupine-node": "^4.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "dotenv": "^16.5.0",
    "duck-duck-scrape": "^2.2.7",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.2",
    "node-edge-tts": "^1.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.daisy.app",
    "productName": "Daisy",
    "directories": {
      "output": "releases"
    },
    "afterPack": "scripts/adhoc-sign.js",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "assets/bin/**",
      "assets/lib/**",
      "assets/models/**",
      "node_modules/uiohook-napi/**",
      "node_modules/ffmpeg-static/**"
    ],
    "dmg": {
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    }
  }
}
